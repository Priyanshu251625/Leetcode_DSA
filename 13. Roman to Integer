class Solution {
    int value(char c) {
        switch (c) {
            case 'I': return 1;
            case 'V': return 5;
            case 'X': return 10;
            case 'L': return 50;
            case 'C': return 100;
            case 'D': return 500;
            default: return 1000;
        }
    }
    public int romanToInt(String s) {
        int n=s.length();
        int i=n-1;
        int sum=value(s.charAt(i--));
        while(i>=0){
            if(value(s.charAt(i))<value(s.charAt(i+1))){
                sum-=value(s.charAt(i--));
            }
            else{
                sum+=value(s.charAt(i--));
            }
        }
        return sum;
    }
}
