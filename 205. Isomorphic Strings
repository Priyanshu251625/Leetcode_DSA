class Solution {
    public boolean isIsomorphic(String s, String t) {
        int[] hash1=new int[256];
        int[] hash2=new int[256];
        int n=s.length();
        for(int i=0;i<n;i++){
            if(hash1[s.charAt(i)]!=hash2[t.charAt(i)]) return false;
            hash1[s.charAt(i)]=i+1;
            hash2[t.charAt(i)]=i+1;
        }
        return true;
    }
}
