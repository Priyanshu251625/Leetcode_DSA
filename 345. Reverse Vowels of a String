class Solution {
    public String reverseVowels(String s) {
        StringBuilder ans=new StringBuilder(s);
        int n=s.length();
        int i=0;
        int j=n-1;
        while(i<=j){
            while(i<n && "AEIOUaeiou".indexOf(s.charAt(i))==-1) i++;
            if(i==n) break;
            while(j>=0 && "AEIOUaeiou".indexOf(s.charAt(j))==-1) j--;
            if(j<0 || j<i) break;
            char temp=ans.charAt(i);
            ans.setCharAt(i,s.charAt(j));
            ans.setCharAt(j,temp);
            i++;j--;
        }
        return ans.toString();
    }
}
