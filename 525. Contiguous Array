class Solution {
    public int findMaxLength(int[] nums) {
        int n=nums.length;
        Map<Integer,Integer>preMap=new HashMap<>();
        int presum=0;
        int len=0;
        for(int i=0;i<n;i++){
            if(nums[i]==0){
                presum-=1;
            }
            else{
                presum+=1;
            }
            if(presum==0){
                len=Math.max(len,i+1);
            }
            else if(preMap.containsKey(presum)){
                len=Math.max(len,i-preMap.get(presum));
            }
            else{
                preMap.put(presum,i);
            }
        }
        return len;
    }
}
