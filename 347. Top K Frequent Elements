class Solution {
    public int[] topKFrequent(int[] nums, int k) {
        Map<Integer,Integer>mpp=new HashMap<>();
        for(int num:nums){
            mpp.put(num,mpp.getOrDefault(num,0)+1);
        }
        PriorityQueue<Integer>pq=new PriorityQueue<>(
            (a,b) -> mpp.get(b)-mpp.get(a)
        );
        pq.addAll(mpp.keySet());
        int[] ans=new int[k];
        for(int i=0;i<k;i++){
            ans[i]=pq.poll();
        }
        return ans;
    }
}
