class Solution {
    public int mySqrt(int x) {
        if(x==0) return 0;
        int low=1;
        int high=x;
        int ans=1;
        while(low<=high){
            long mid=((long)low+(long)high)/(long)2;
            if(mid*mid<=(long)x){
                ans=(int)mid;
                low=(int)mid+1;
            }
            else{
                high=(int)mid-1;
            }
        }
        return ans;
    }
}
