class Solution {
    public int maxDepth(String s) {
        int n=s.length();
        int max_Depth=0;
        int count=0;
        for(int i=0;i<n;i++){
            if(s.charAt(i)=='('){
                count++;
            }
            else if(s.charAt(i)==')'){
                count--;
            }
            max_Depth=Math.max(max_Depth,count);
        }
        return max_Depth;
    }
}
