class Solution {
    public String digitSum(String s, int k) {
        while(s.length()>k){
            int n=s.length();
            int num=0;
            StringBuilder sb=new StringBuilder();
            int i=0;
            while(i<n){
                num+=s.charAt(i)-'0';
                i++;
                if(i%k==0){
                    sb.append(String.valueOf(num));
                    num=0;
                }
            }
            if(n%k!=0)sb.append(String.valueOf(num));
            s=sb.toString();
        }
        return s;
    }
}
