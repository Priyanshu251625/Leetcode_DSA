class Solution {
    boolean possible(int[] position,int magForce,int balls){
        int n=position.length;
        int distributed=1;
        int last=position[0];
        for(int i=1;i<n;i++){
            if(position[i]-last>=magForce){
                distributed++;
                last=position[i];
            }
            if(distributed>=balls){
                return true;
            }
        }
        return false;
    }
    public int maxDistance(int[] position, int m) {
        int n=position.length;
        Arrays.sort(position);
        int low=1;
        int high=position[n-1]-position[0];
        while(low<=high){
            int mid=(low+high)/2;
            if(possible(position,mid,m)){
                low=mid+1;
            }
            else high=mid-1;
        }
        return high;
    }
}
