class Solution {
    public int compress(char[] chars) {
        int n=chars.length;
        int readIndex=0;
        int writeIndex=0;
        while(readIndex<n){
            char currentChar=chars[readIndex];
            int count=0;
            while(readIndex<n && chars[readIndex]==currentChar){
                readIndex++;
                count++;
            }
            chars[writeIndex++]=currentChar;
            if(count>1){
                String cnt=String.valueOf(count);
                for(char ch:cnt.toCharArray()){
                    chars[writeIndex++]=ch;
                }
            }
        }
        return writeIndex;
    }
}
