class Solution {
    boolean isoMorphic(String s, String t){
        int[] hash1=new int[26];
        int[] hash2=new int[26];
        int n=s.length();
        for(int i=0;i<n;i++){
            if(hash1[s.charAt(i)-97]!=hash2[t.charAt(i)-97]) return false;
            hash1[s.charAt(i)-97]=i+1;
            hash2[t.charAt(i)-97]=i+1;
        }
        return true;
    }
    public List<String> findAndReplacePattern(String[] words, String pattern) {
        List<String> ans=new ArrayList<>();
        for(String wrd: words){
            if(isoMorphic(pattern,wrd)){
                ans.add(wrd);
            }
        }
        return ans;
    }
}
