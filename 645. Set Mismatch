class Solution {
    public int[] findErrorNums(int[] nums) {
        int n=nums.length;
        int[] freq=new int[n+1];
        for(int i=0;i<n;i++){
            freq[nums[i]]++;
        }
        int[] ans={0,0};
        for(int i=0;i<=n;i++){
            if(freq[i]==0){
                ans[1]=i;
            }
            else if(freq[i]==2){
                ans[0]=i;
            }
        }
        return ans;
    }
}
